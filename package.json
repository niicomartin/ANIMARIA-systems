{
  "name": "animaria-system",
  "version": "0.1.0",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "prepare-electron": "node scripts/prepare-electron.js",
    "dist": "npm run build && npm run prepare-electron && electron-builder"
  },
  "dependencies": {
    "@prisma/client": "^7.8.0",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "mysql2": "^3.22.3",
    "next": "16.2.5",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "electron": "^42.1.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.5",
    "prisma": "^7.8.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "build": {
    "appId": "com.animaria.sistema",
    "productName": "ANIMARIA",

    "directories": {
      "output": "dist"
    },

    "files": [
      "electron/**/*",
      "build/icon.ico",
      ".next/standalone/**/*",
      ".next/standalone/.next/static/**/*",
      ".next/standalone/public/**/*",
      ".env",
      "package.json"
    ],

    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },

    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "ANIMARIA"
    },

    "asar": false
  }
}